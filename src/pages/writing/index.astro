---
import ProseLayout from "@/layouts/ProseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<ProseLayout title="Writing" description="Essays, short fiction, and creative non-fiction.">
  <h1 class="font-display text-3xl mb-12">Writing</h1>
  <ul class="space-y-8">
    {posts.map((post) => (
      <li>
        <a href={`/writing/${post.slug}/`} class="group block">
          <time class="text-sm text-gray-400">{post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
          <h2 class="text-lg font-medium group-hover:text-accent transition-colors">{post.data.title}</h2>
          {post.data.description && <p class="text-gray-500 text-sm mt-1">{post.data.description}</p>}
        </a>
      </li>
    ))}
  </ul>
</ProseLayout>
