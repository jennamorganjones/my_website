---
import GalleryLayout from "@/layouts/GalleryLayout.astro";

const CHANNEL_SLUG = "oil-on-the-spoon";
const PER_PAGE = 100;

let blocks = [];
try {
  const res = await fetch(`https://api.are.na/v3/channels/${CHANNEL_SLUG}/contents?per=${PER_PAGE}&page=1`, { signal: AbortSignal.timeout(10000) });
  const page1 = await res.json();
  blocks = (page1.data || []).filter(b => b.type === "Image" && b.image?.medium?.src);
} catch (e) {
  console.warn("Are.na fetch failed:", e.message);
}
---

<GalleryLayout title="oil on the spoon" description="A visual collection from Are.na.">
  <h1 class="font-display text-2xl mb-2">oil on the spoon</h1>
  <p class="text-sm text-gray-400 mb-10">
    <a href={`https://www.are.na/jenna-morgan/${CHANNEL_SLUG}`} class="underline hover:text-accent" target="_blank" rel="noopener">view on Are.na</a>
  </p>
  {blocks.length > 0 ? (
    <div class="columns-2 sm:columns-3 gap-3 space-y-3">
      {blocks.map((block) => (
        <figure class="break-inside-avoid">
          <img
            src={block.image.medium.src}
            alt={block.title || ""}
            width={block.image.width}
            height={block.image.height}
            class="w-full h-auto"
            loading="lazy"
            decoding="async"
          />
        </figure>
      ))}
    </div>
  ) : (
    <p class="text-gray-400">Loading from Are.na failed — try refreshing.</p>
  )}
</GalleryLayout>
