---
interface ImageItem {
  src: string;
  alt: string;
}

type Row = { layout: "full"; image: ImageItem } | { layout: "pair"; images: [ImageItem, ImageItem] };

interface Props {
  rows: Row[];
}

const { rows } = Astro.props;
---

{rows.map((row) =>
  row.layout === "pair" ? (
    <div class="grid grid-cols-2 gap-2">
      {row.images.map((img) => (
        <figure>
          <img src={img.src} alt={img.alt} class="w-full h-auto" loading="lazy" decoding="async" />
        </figure>
      ))}
    </div>
  ) : (
    <figure>
      <img src={row.image.src} alt={row.image.alt} class="w-full h-auto" loading="lazy" decoding="async" />
    </figure>
  )
)}
