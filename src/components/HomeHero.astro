---
const links = [
  { text: "writing", href: "/writing/", x: "10%", y: "45%" },
  { text: "photos", href: "/photos/", x: "15%", y: "78%" },
  { text: "artwork", href: "/artworks/", x: "48%", y: "70%" },
  { text: "about this website", href: "/colophon/", x: "58%", y: "48%" },
  { text: "about me", href: "/about/", x: "72%", y: "88%" },
  { text: "let's connect", href: "/connect/", x: "72%", y: "15%" },
];
---

<section class="relative w-full h-screen overflow-hidden">
  <!-- Desktop hero -->
  <picture>
    <source media="(max-width: 768px)" srcset="/images/hero-mobile.jpg" />
    <img
      src="/images/hero.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <!-- Scattered navigation links -->
  {links.map((link) => (
    <a
      href={link.href}
      class="absolute font-display text-white text-lg md:text-xl p-3 hover:opacity-70 transition-opacity"
      style={`left:${link.x}; top:${link.y}`}
    >
      {link.text}
    </a>
  ))}
</section>
